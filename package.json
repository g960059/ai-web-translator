{
  "name": "ai-web-translator",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Translate web pages using OpenRouter AI",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:live": "npm run build && RUN_LIVE_E2E=1 playwright test tests/e2e/live-translation.spec.ts",
    "test:e2e:live:page": "npm run build && node tests/e2e/run-live-page-metrics.mjs",
    "metrics:compare": "node tests/e2e/compare-live-metrics.mjs",
    "metrics:model-eval": "npm run build && node tests/e2e/run-live-fixture-model-eval.mjs"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.23",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.0.263",
    "@types/node": "^22.13.10",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "dotenv": "^17.3.1",
    "jsdom": "^26.0.0",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "vitest": "^3.1.1"
  }
}

{
  "manifest_version": 3,
  "name": "AI Web Translator",
  "version": "1.0.0",
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://openrouter.ai/*"
  ],
  "content_scripts": [
    {
      "js": [
        "assets/index.ts-Cxs4mnlp.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/index.ts-Cxs4mnlp.js"
      ],
      "use_dynamic_url": false
    }
  ]
}

{
    "manifest_version": 3,
    "name": "AI Web Translator",
    "version": "1.0.0",
    "action": {
        "default_popup": "src/popup/index.html"
    },
    "permissions": [
        "storage",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "https://openrouter.ai/*"
    ],
    "content_scripts": [
        {
            "js": [
                "src/content/index.ts"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "background": {
        "service_worker": "src/background/index.ts",
        "type": "module"
    }
}
{
  "manifest_version": 3,
  "name": "AI Web Translator",
  "version": "2.0.0",
  "description": "Translate web pages with AI and manage translation sessions from a focused popup.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "commands": {
    "translate-page": {
      "suggested_key": {
        "default": "Alt+T",
        "mac": "Alt+T"
      },
      "description": "このページを翻訳"
    },
    "toggle-translation": {
      "suggested_key": {
        "default": "Alt+O",
        "mac": "Alt+O"
      },
      "description": "原文と翻訳を切り替え"
    },
    "translate-selection": {
      "suggested_key": {
        "default": "Alt+Shift+T",
        "mac": "Alt+Shift+T"
      },
      "description": "選択範囲を翻訳"
    }
  },
  "permissions": [
    "storage",
    "activeTab",
    "contextMenus",
    "tabs"
  ],
  "host_permissions": [
    "https://openrouter.ai/*"
  ],
  "content_scripts": [
    {
      "js": [
        "src/entrypoints/content.ts"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/entrypoints/background.ts",
    "type": "module"
  }
}
